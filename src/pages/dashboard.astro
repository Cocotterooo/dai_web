---
import Layout from "../layouts/Layout.astro";
import Button from "../components/ui/Button.astro";
import DAILogo from "../components/common/DAILogo.astro";

/*console.log('=== DASHBOARD CON MIDDLEWARE ===');
console.log('Usuario desde middleware:', Astro.locals.user?.email);
console.log('👤 Metadatos completos del usuario:', {
  user_metadata: Astro.locals.user?.user_metadata,
  app_metadata: Astro.locals.user?.app_metadata,
  hasAvatar: !!Astro.locals.user?.user_metadata?.avatar_url,
  avatarUrl: Astro.locals.user?.user_metadata?.avatar_url,
});*/


// Los datos del usuario vienen del middleware
const user = Astro.locals.user;
const email = Astro.locals.email;
const profile = (Astro.locals as any).profile; // Perfil extendido si existe
const isAuthenticated = !!user;

console.log('= Dashboard User:', email);
console.log('Estado de autenticación:', {
  isAuthenticated,
  email,
  userId: user?.id,
  hasProfile: !!profile,
  userData: {
    name: user?.user_metadata?.full_name || user?.user_metadata?.name,
    phone: user?.user_metadata?.phone || profile?.phone,
    dni: user?.user_metadata?.dni || profile?.dni,
    avatar: user?.user_metadata?.avatar_url || user?.user_metadata?.picture,
  },
});
---

<Layout title="Dashboard - DAI">
  <main class="min-h-screen p-6 mt-16">
    <div class="max-w-6xl mx-auto">
      
      {/* Loading state si venimos del callback */}
      {!isAuthenticated && (
        <div id="loading-state" class="text-center py-20">
          <div class="bg-white/10 backdrop-blur-xl border border-white/20 shadow-2xl rounded-2xl p-8">
            <div class="animate-spin w-12 h-12 border-4 border-white/20 border-t-white rounded-full mx-auto mb-4"></div>
            <h2 class="text-2xl font-bold text-white mb-2">Error de autenticación</h2>
            <p class="text-white/80">No se pudo verificar tu sesión</p>
            <a href="/auth" class="mt-4 inline-block bg-dai hover:bg-dai/80 text-white px-4 py-2 rounded-lg">
              Ir al login
            </a>
          </div>
        </div>
      )}
      
      {/* Dashboard normal si está autenticado */}
      {isAuthenticated && user && (
        <>
          <!-- Header -->
          <div class="flex items-center justify-between mb-8">
            <DAILogo size="sm" />
            <a 
              href="/api/auth/signout"
              class="bg-red-500 hover:bg-red-600 text-white px-4 py-2 rounded-lg transition-colors duration-300"
            >
              Cerrar sesión
            </a>
          </div>

          <!-- Notificación para completar perfil -->
          {user.app_metadata?.provider !== 'email' && (!user.user_metadata?.phone || !user.user_metadata?.dni) && (
            <div class="bg-yellow-500/20 backdrop-blur-xl border border-yellow-500/30 shadow-2xl rounded-2xl p-6 mb-8">
              <div class="flex items-center gap-3">
                <svg class="w-6 h-6 text-yellow-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.732-.833-2.464 0L4.35 16.5c-.77.833.192 2.5 1.732 2.5z"></path>
                </svg>
                <div class="flex-1">
                  <h3 class="text-lg font-semibold text-yellow-200">Perfil incompleto</h3>
                  <p class="text-yellow-200/80 text-sm">
                    Para acceder a todos los servicios de DAI, necesitas completar tu DNI y teléfono.
                  </p>
                </div>
                <a 
                  href="/complete-profile"
                  class="bg-yellow-500 hover:bg-yellow-600 text-yellow-900 px-4 py-2 rounded-lg font-medium transition-colors"
                >
                  Completar ahora
                </a>
              </div>
            </div>
          )}

          <!-- Bienvenida -->
          <div class="bg-white/10 backdrop-blur-xl border border-white/20 shadow-2xl rounded-2xl p-8 mb-8">
            <div class="flex items-center gap-4">
              {(user.user_metadata?.avatar_url || user.user_metadata?.picture) && (
                <img 
                  src={user.user_metadata.avatar_url || user.user_metadata.picture} 
                  alt="Avatar" 
                  class="w-16 h-16 rounded-full border-2 border-white/20"
                />
              )}
              <div>
                <h1 class="text-3xl font-bold text-white mb-2">
                  ¡Bienvenido, {user.user_metadata?.full_name || user.user_metadata?.name || user.email}!
                </h1>
                <p class="text-white/80">
                  Has iniciado sesión correctamente
                </p>
              </div>
            </div>
            
            <!-- Info del usuario -->
            <div class="mt-6 p-4 bg-white/5 rounded-lg">
              <h3 class="text-lg font-semibold text-white mb-3">Información de la cuenta:</h3>
              <div class="grid grid-cols-1 md:grid-cols-2 gap-4 text-white/90">
                <div>
                  <span class="font-medium text-white">Email:</span> 
                  <span class="ml-2">{user.email}</span>
                </div>
                <div>
                  <span class="font-medium text-white">Nombre:</span>
                  <span class="ml-2">{user.user_metadata?.full_name || user.user_metadata?.name || profile?.full_name || 'No especificado'}</span>
                </div>
                <div>
                  <span class="font-medium text-white">Teléfono:</span>
                  <span class="ml-2">{user.user_metadata?.phone || profile?.phone || 'No especificado'}</span>
                </div>
                <div>
                  <span class="font-medium text-white">DNI:</span>
                  <span class="ml-2">{user.user_metadata?.dni || profile?.dni || 'No especificado'}</span>
                </div>
                <div>
                  <span class="font-medium text-white">Proveedor:</span>
                  <span class="ml-2 capitalize">{user.app_metadata?.provider || 'Email'}</span>
                </div>
                <div>
                  <span class="font-medium text-white">Última conexión:</span>
                  <span class="ml-2 text-sm">{new Date(user.last_sign_in_at || '').toLocaleDateString()}</span>
                </div>
              </div>
            </div>
          </div>

          <!-- Cards de funcionalidades -->
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mb-8">
            
            <!-- Card Perfil -->
            <div class="bg-white/10 backdrop-blur-xl border border-white/20 shadow-2xl rounded-2xl p-6">
              <div class="flex items-center gap-3 mb-4">
                <div class="w-12 h-12 bg-dai rounded-full flex items-center justify-center">
                  <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
                  </svg>
                </div>
                <h3 class="text-xl font-semibold text-white">Mi Perfil</h3>
              </div>
              <p class="text-white/80 mb-4">Gestiona tu información personal y preferencias de cuenta</p>
              <Button variant="primary" size="sm" className="w-full">
                Editar Perfil
              </Button>
            </div>

            <!-- Card Servicios -->
            <div class="bg-white/10 backdrop-blur-xl border border-white/20 shadow-2xl rounded-2xl p-6">
              <div class="flex items-center gap-3 mb-4">
                <div class="w-12 h-12 bg-azul-brillante rounded-full flex items-center justify-center">
                  <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path>
                  </svg>
                </div>
                <h3 class="text-xl font-semibold text-white">Servicios DAI</h3>
              </div>
              <p class="text-white/80 mb-4">Accede a todos los servicios y recursos disponibles</p>
              <Button variant="primary" size="sm" className="w-full">
                Ver Servicios
              </Button>
            </div>

            <!-- Card Notificaciones -->
            <div class="bg-white/10 backdrop-blur-xl border border-white/20 shadow-2xl rounded-2xl p-6">
              <div class="flex items-center gap-3 mb-4">
                <div class="w-12 h-12 bg-purple-600 rounded-full flex items-center justify-center">
                  <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-5 5v-5zM12 17H7l5 5v-5zM12 3C9.236 3 7 5.236 7 8v7l-4 2v1h22v-1l-4-2V8c0-2.764-2.236-5-5-5z"></path>
                  </svg>
                </div>
                <h3 class="text-xl font-semibold text-white">Notificaciones</h3>
              </div>
              <p class="text-white/80 mb-4">Revisa tus notificaciones y mensajes importantes</p>
              <Button variant="primary" size="sm" className="w-full">
                Ver Todas
              </Button>
            </div>

          </div>

          <!-- Enlaces de navegación -->
          <div class="text-center">
            <a 
              href="/" 
              class="text-white/80 hover:text-white transition-colors duration-300 inline-flex items-center gap-2"
            >
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
              </svg>
              Volver al inicio
            </a>
          </div>
        </>
      )}

    </div>
  </main>
</Layout>
