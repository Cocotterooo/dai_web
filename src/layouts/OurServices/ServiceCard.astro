---
const { title, description, image, imageClass } = Astro.props;
---
<div class="flex flex-col items-center justify-center p-4 bg-dai/5 rounded-lg shadow-md max-w-md mx-auto">
    <div class={`pd-4 rounded-full bg-dai/5 border border-dai/10 w-[130px] h-[130px] flex items-center justify-center mb-5 ${imageClass}`}>
        <animated-icons
        src={image}
        trigger="loop"
        attributes='{"type":"custom","id":1749340059127,"style":"minimalistic","strokeWidth":2.1799999999999997,"variationNumber":2,"numberOfGroups":2,"backgroundIsGroup":false,"defaultColours":{"group-1":"#FFFFFFFF","group-2":"#00ACE2FF","background":"#FFFFFF00"},"variationName":"dai"}'
        height="100"
        width="100"
        speed="0.5"
        ></animated-icons>    
    </div>
    <div>
        <div>
            <h2 class="text-3xl font-bold text-azul-brillante">
                {title}
            </h2>
            <p class="text-wrap w-[30ch]">
                {description}
            </p>
            <a href="">
                <button class="mt-4 px-6 py-2 border-dai border text-dai hover:border-azul-brillante hover:text-azul-brillante rounded hover:bg-dai/10 transition-colors cursor-pointer">
                    Más Información
                </button>
            </a>
        </div>
    </div>
</div>

<script src="../../scripts/embed-animated-icons.js"></script>