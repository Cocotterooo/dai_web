---
import InstagramIcon from "@/assets/social/instagram.svg";
import InstagramLogo from "@/assets/social/InstagramLogo.svg";
import Usuarios from "@/assets/icons/usuarios.svg";

const followers = 1301;
const posts = 56; 
const instagramProfileUrl = "https://www.instagram.com/tu_perfil_dai/";
---

<div class="card rounded-2xl w-full min-w-[350px] max-w-[350px]">
    <div class="bg-blue-950/30 w-full h-full flex flex-col rounded-[16px] justify-between p-4">
        <div class="flex flex-row items-center">
            <InstagramIcon class="w-10 h-10" />
            <span class="font-bold text-[18px] text-white ml-2 text-grad">
                @dai_uvigo
            </span>
        </div>
        <div class="flex flex-col justify-between items-start w-full h-full z-10">
            <div class="flex flex-row justify-end gap-1 w-full text-sm text-white/70 items-center">
                <Usuarios class="w-4 h-4" />
                {followers} Seguidores
            </div>
            <p class="text-pretty text-left font-extralight text-sm text-white/80">
                Sigue a la <strong class="text-instagram-3 font-bold">Delegación de Alumnos</strong> en Instagram y entérate de todo lo que pasa en la <strong class="text-instagram-4 font-bold">Escuela de Ingeniería Industrial</strong>.


            </p>
            <a href="#" class="relative w-full text-center text-white font-bold py-2 rounded-lg overflow-hidden z-20
            bg-gradient-to-r from-[#ff7a00] via-[#ff0069] to-[#7638fa]
            transition-all duration-300 ease-in-out hover:brightness-130 shadow-md
            before:absolute before:inset-0 before:bg-[conic-gradient(#ff7a00,#ff0069,#d300c5,#7638fa,#ffd600)]
            before:opacity-0 hover:before:opacity-20 before:transition-opacity before:duration-500"
   >
                Síguenos en Instagram
            </a>
        </div>
    </div>
</div>

<style>
    .card {
  background: var(--color-azul-oscuro); /* Fondo base si el interior no cubre todo */
  border-radius: 16px; /* Coincide con rounded-2xl */
  box-sizing: border-box;
  position: relative;
  /* ¡ASEGÚRATE DE NO TENER overflow: hidden aquí! */
  /* min-w-[230px] w-[350px] - desde el HTML */
}

@property --angle {
  syntax: "<angle>";
  initial-value: 0deg;
  inherits: false;
}

.card::after,
.card::before {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  translate: -50% -50%; /* Mantenemos el centrado */

  /* --- CAMBIOS PRINCIPALES --- */
  width: calc(100% + 4px); /* Hacemos que sea 2px más ancho (1px por cada lado) */
  height: calc(100% + 3px); /* Hacemos que sea 2px más alto (1px por arriba/abajo) */
  /* padding: 1px; */ /* <-- ELIMINAR ESTO */
  /* --- FIN CAMBIOS --- */

  background-image: conic-gradient(
      from var(--angle),
      var(--color-instagram-2),
      var(--color-instagram-3),
      var(--color-instagram-1),
      var(--color-instagram-5),
      var(--color-instagram-4),
      var(--color-instagram-2)
  );
  border-radius: 16px; /* Mantenemos el radio */
  z-index: -1; /* Detrás del contenido */
  animation: spin 10s linear infinite;
  box-sizing: border-box; /* Mantenemos border-box */
}

.card::before {
  filter: blur(12px); /* El glow exterior se mantiene */
  opacity: 0.5;
}

@keyframes spin {
  from {
      --angle: 0deg;
  }
  to {
      --angle: 360deg;
  }
}
</style>
