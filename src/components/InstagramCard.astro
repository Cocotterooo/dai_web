---
import InstagramIcon from "@/assets/social/instagram.svg";
import InstagramLogo from "@/assets/social/InstaLogotipe.svg";
import Usuarios from "@/assets/icons/usuarios.svg";

const followers = 1301;
const posts = 56; 
const instagramProfileUrl = "https://www.instagram.com/dai_uvigo/";
---

<div class="gradient rounded-2xl w-full min-w-[350px] max-w-[350px] h-[222.5px]">
    <div class="relative bg-blue-950/30 w-full h-full flex flex-col rounded-2xl justify-end px-4 pt-13.5 pb-4">
        <!-- Logo fijo en la esquina superior izquierda, separado 4px -->
        <div class="absolute top-4 left-4 z-20 flex flex-row items-center gap-2">
            <InstagramIcon class="w-8 h-8" />
            <InstagramLogo class="w-30 translate-y-1" />
        </div>

        <!-- @dai_uvigo en la esquina superior derecha -->
        <a href={instagramProfileUrl} target="_blank" class="absolute top-4 right-4 text-md text-dai z-20 bg-dai/20 px-2 rounded-full border-dai/30 border hover:bg-dai/30 transition-colors duration-300">
            @dai_uvigo
        </a>

        <!-- Contenido al fondo -->
        <div class="flex flex-col justify-start w-full h-full z-10 gap-3">
            <div class="flex flex-row justify-end gap-1 w-full text-sm text-white/70 mb-2">
                <Usuarios class="w-4 h-4" />
                {followers} Seguidores
            </div>
            <p class="text-pretty text-left font-extralight text-sm text-white/80">
                Sigue a la <strong class="text-instagram-3 font-bold">Delegación de Alumnos</strong> en Instagram y entérate de todo lo que pasa en la <strong class="text-instagram-4 font-bold">Escuela de Ingeniería Industrial</strong>.
            </p>
            <a href={instagramProfileUrl} target="_blank" class="relative w-full text-center text-white font-bold py-2 rounded-lg overflow-hidden z-20
            bg-linear-to-r from-instagram-2 via-instagram-3 to-instagram-5
            transition-all duration-700 ease-in-out hover:brightness-130 shadow-md
            before:absolute before:inset-0 before:bg-[conic-gradient(#ff7a00,#ff0069,#d300c5,#7638fa,#ffd600)]
            before:opacity-0 hover:before:opacity-20 before:transition-opacity before:duration-700">
                <span>Síguenos en Instagram</span>
            </a>
        </div>
    </div>
</div>


<style>
    .gradient {
  background: var(--color-azul-oscuro); /* Fondo base si el interior no cubre todo */
  border-radius: 16px; /* Coincide con rounded-2xl */
  box-sizing: border-box;
  position: relative;
  /* ¡ASEGÚRATE DE NO TENER overflow: hidden aquí! */
  /* min-w-[230px] w-[350px] - desde el HTML */
}

@property --angle {
  syntax: "<angle>";
  initial-value: 0deg;
  inherits: false;
}

.gradient::after,
.gradient::before {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  translate: -50% -50%; /* Mantenemos el centrado */

  /* --- CAMBIOS PRINCIPALES --- */
  width: calc(100% + 4px); /* Hacemos que sea 2px más ancho (1px por cada lado) */
  height: calc(100% + 3px); /* Hacemos que sea 2px más alto (1px por arriba/abajo) */
  /* padding: 1px; */ /* <-- ELIMINAR ESTO */
  /* --- FIN CAMBIOS --- */

  background-image: conic-gradient(
      from var(--angle),
      var(--color-instagram-2),
      var(--color-instagram-3),
      var(--color-instagram-1),
      var(--color-instagram-5),
      var(--color-instagram-4),
      var(--color-instagram-2)
  );
  border-radius: 16px; /* Mantenemos el radio */
  z-index: -1; /* Detrás del contenido */
  animation: spin 10s linear infinite;
  box-sizing: border-box; /* Mantenemos border-box */
}

.gradient::before {
  filter: blur(12px); /* El glow exterior se mantiene */
  opacity: 0.5;
}

@keyframes spin {
  from {
      --angle: 0deg;
  }
  to {
      --angle: 360deg;
  }
}
</style>
