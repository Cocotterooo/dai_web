---
import Discord from "@/assets/social/discord_complete.svg";
import Usuarios from "@/assets/icons/usuarios.svg";

const users = 1698; // Example number of users
const onlineUsers = 105; // Example number of online users
---
<div class="flex flex-col justify-start items-start bg-blue-950/30 rounded-2xl p-4 gap-2 w-full min-w-[350px] max-w-[350px] border-[#5865F2]/90 border-3 shadow-[0_0_11px_2px_#5865F2] backdrop-blur-sm relative z-10">
    <div class="flex flex-row justify-between w-full">
        <div class="flex flex-row items-center gap-2">
            <Discord class="w-auto h-6" />
            <h1 class="text-2xl text-white"></h1>
        </div>
        <div class="flex items-center">
            <div class="flex flex-row items-center h-full rounded-full border-emerald-500/50 border-1 bg-emerald-500/15 px-3 py-0.5 text-left font-extralight text-sm text-emerald-500 gap-1.5">
                <span class="relative flex h-2 w-2">
                    <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75 shadow-[0_0_6px_2px_rgba(74,222,128,0.5)]"></span>
                    <span class="relative inline-flex rounded-full h-2 w-2 bg-emerald-500 shadow-[0_0_4px_1px_rgba(74,222,128,0.7)]"></span>
                </span>
                <span>{onlineUsers} Online</span>
            </div>
        </div>
    </div>
    <div class="flex flex-row justify-end gap-1 w-full text-sm text-white/70 items-center">
        <Usuarios class="w-4 h-4" />
        {users} miembros
    </div>
    <div class="flex flex-col justify-start items-start w-full h-full gap-3 relative z-10">
        <p class="text-pretty text-left font-extralight text-sm text-white/80">
            Únete a la comunidad <strong class="text-azul-brillante font-bold">oficial</strong> de estudiantes de la <strong class="text-azul-brillante font-bold">Escuela de Ingeniería Industrial de la UVigo</strong> y mantente al día con las últimas noticias y eventos.
        </p>
        <a href="#" id="discord-join" class="rounded-lg bg-[#5865F2]/80 py-2 w-full text-center text-white font-bold hover:bg-[#5865F2] transition-colors z-20">
            Unirse al servidor
        </a>
    </div>
</div>